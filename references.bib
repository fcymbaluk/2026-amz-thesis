@article{souza2022,
  title = {{{TD}} 2813 - {{Uma}} Avalia\c c\~ao Final Da Focaliza\c c\~ao e Da Efetividade Contra a Pobreza Do {{Programa Bolsa Fam\'ilia}}, Em Perspectiva Comparada},
  author = {Souza, Pedro H. G. Ferreira De and Bruce, Raphael},
  year = 2022,
  month = nov,
  journal = {Texto para Discuss\~ao},
  pages = {1--83},
  doi = {10.38116/td2813},
  urldate = {2026-02-24},
  abstract = {Este trabalho se prop\~oe a entender qu\~ao boa foi a focaliza\c c\~ao do Programa Bolsa Fam\'ilia (PBF) e qu\~ao eficaz ele foi no combate \`a pobreza no Brasil entre 2004 e 2019. Por meio de dados da Pesquisa Nacional por Amostra de Domic\'ilios (PNAD) de 2004 a 2015, da PNAD Cont\'inua a partir de 2012 a 2019 e do Atlas of Social Protection Indicators of Resilience and Equity (Aspire), calculamos diferentes indicadores para medidas de focaliza\c c\~ao e pobreza para obter um panorama de como o programa funcionou ao longo do per\'iodo analisado. Al\'em disso, comparamos a focaliza\c c\~ao com a de programas semelhantes de outros pa\'ises para apresentar o PBF em perspectiva internacional. Nossos resultados indicam que o PBF obteve boa focaliza\c c\~ao, com n\'iveis baixos de erros de inclus\~ao (isto \'e, pessoas que n\~ao deveriam receber o benef\'icio, por\'em o recebem) e n\'iveis moderados para os erros de exclus\~ao (ou seja, pessoas que deveriam receber o benef\'icio, por\'em n\~ao o recebem). Em perspectiva internacional, o PBF \'e bem focalizado, ficando entre os melhores programas de nossa amostra, independentemente da linha de pobreza ou m\'etrica de focaliza\c c\~ao utilizada. No que diz respeito ao efeito sobre a redu\c c\~ao de pobreza, os resultados sugerem um papel importante do PBF, especialmente quando s\~ao utilizadas linhas de pobreza mais baixas. No entanto, para essas linhas, o efeito do PBF sobre a pobreza diminuiu ao longo do tempo. Em especial, n\~ao houve um aumento do papel do PBF sobre a redu\c c\~ao de pobreza entre 2012 e 2019. Conclu\'imos ent\~ao que a prioridade para os pr\'oximos anos \'e reduzir os erros de exclus\~ao e manter ou elevar o valor real dos benef\'icios.},
  file = {/Users/fcymbaluk/Zotero/storage/4QNF8KC3/Souza and Bruce - 2022 - TD 2813 - Uma avaliação final da focalização e da efetividade contra a pobreza do Programa Bolsa Fam.pdf}
}

@book{sowersOxfordHandbookComparative2023,
  title = {The {{Oxford Handbook}} of {{Comparative Environmental Politics}}},
